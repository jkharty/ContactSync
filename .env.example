# ============================================================
#  ContactSync — environment variable template
#  Copy this file to .env and fill in your real values.
#  .env is gitignored and never committed.
# ============================================================

# Microsoft 365 / Azure App Registration
# Get these from: Azure Portal → App Registrations → your app
TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Mailbox whose Contacts folder is synced
MAILBOX_EMAIL=you@yourdomain.com

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# User accounts (format: username:password:role, comma-separated)
# Roles: readonly | editor | admin
USERS=viewer:password1:readonly,editor:password2:editor,admin:password3:admin

# Sync interval in seconds (600 = 10 min, 300 = 5 min minimum recommended)
SYNC_INTERVAL_SECONDS=600

# Web server port
WEB_PORT=5000

# Database path
# Local:  instance/contacts.db
# Azure:  /home/data/contacts.db
DB_PATH=instance/contacts.db
